                    )}
                  </div>
                ))}
              </div>
            </>
          )}

          {s.id === "accion" && (
            <div class="topic__orgs">
              <a href="https://mareaverdepanama.org" target="_blank" rel="noopener noreferrer" class="topic__org-link">
