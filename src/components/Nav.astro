---
const navLinks = [
  { label: "¿Qué es?",    href: "#relleno"    },
  { label: "Ambiente",    href: "#ambiental"  },
  { label: "Comunidades", href: "#comunitario"},
  { label: "Actualidad",  href: "#pasando"    },
  { label: "Planes",      href: "#prevencion" },
  { label: "Acción",      href: "#accion"     },
];
---

<nav class="nav" aria-label="Main navigation">
  <div class="container nav__inner">
    <div class="nav__left">
      <a href="https://alexandrasofiacohen.com" class="nav__logo-link">
        <img src="/images/logo-favicon.svg" alt="Alexandra Cohen" class="nav__logo-mark" />
      </a>
      <a href="https://alexandrasofiacohen.com" class="nav__back-home">← Volver al Inicio</a>
    </div>
    <ul class="nav__links" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav__link">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 70px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 1px 0 rgba(46, 125, 82, 0.07);
    transition: transform 0.3s ease;
  }

  .nav__inner {
    height: 100%;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .nav__left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav__logo-link {
    display: flex;
    align-items: center;
  }

  .nav__logo-mark {
    height: 40px;
    width: 40px;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    list-style: none;
    overflow-x: auto;
  }

  .nav__link {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
    padding-bottom: 2px;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent-2);
    transition: width 0.2s;
  }

  .nav__link:hover {
    color: var(--color-accent-2);
    text-decoration: none;
  }

  .nav__link:hover::after {
    width: 100%;
  }

  .nav__back-home {
    color: var(--color-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .nav__back-home:hover {
    color: var(--color-accent);
  }

  .nav--hidden {
    transform: translateY(-100%);
  }

  @media (max-width: 600px) {
    .nav__links { gap: 0.9rem; }
    .nav__link  { font-size: 0.75rem; }
  }
</style>

<script>
  const nav = document.querySelector('.nav');
  let lastY = window.scrollY;

  window.addEventListener('scroll', () => {
    const currentY = window.scrollY;
    if (currentY > lastY && currentY > 50) {
      nav.classList.add('nav--hidden');
    } else {
      nav.classList.remove('nav--hidden');
    }
    lastY = currentY;
  });
</script>

