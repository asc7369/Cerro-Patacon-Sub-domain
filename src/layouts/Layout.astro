---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cerro Patacón: De crisis a oportunidad",
  description = "Una mirada investigativa al único relleno sanitario de Ciudad de Panamá y las comunidades que viven a su sombra.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ── CSS Custom Properties ── */
  :root {
    --color-bg:          #f0ebe2;   /* warm cream */
    --color-surface:     #faf7f2;   /* soft warm white for cards */
    --color-surface-alt: #d4dfd0;   /* muted sage green for sections */
    --color-border:      #b8c9b4;   /* muted sage border */
    --color-text:        #1e3a28;   /* deep forest green */
    --color-muted:       #527a62;   /* medium green-gray */
    --color-accent:      #2e7d52;   /* forest green — primary */
    --color-accent-2:    #2e7d52;   /* same as primary green */
    --color-hero-bg:     #0c2618;   /* very dark forest green for hero / footer */

    --font-body:    'DM Sans', system-ui, sans-serif;
    --font-display: 'Playfair Display', Georgia, serif;

    --max-width: 1160px;
    --section-pad: clamp(4rem, 10vw, 8rem);
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-2);
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .section-intro {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.8;
  }

  .divider {
    width: 3rem;
    height: 3px;
    background: var(--color-accent);
    border: none;
    margin-bottom: 2rem;
  }
</style>
